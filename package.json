{
  "name": "@vijayhardaha/video2pdf",
  "version": "1.0.3",
  "description": "A CLI tool to convert video files to PDF by extracting frames using FFmpeg.",
  "scripts": {
    "start": "node dist/index.js",
    "build": "vite build",
    "lint": "eslint . --ext .ts,.tsx,.js,.mjs",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.mjs --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,css,md,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,css,md,yml}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "tsc": "tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "release": "release-it",
    "release:dry": "release-it --dry-run",
    "prepare": "husky"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "main": "dist/index.js",
  "bin": {
    "video2pdf": "dist/index.js"
  },
  "license": "MIT",
  "author": {
    "name": "Vijay Hardaha",
    "url": "https://github.com/vijayhardaha"
  },
  "homepage": "https://github.com/vijayhardaha/video2pdf-cli#readme",
  "bugs": {
    "url": "https://github.com/vijayhardaha/video2pdf-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vijayhardaha/video2pdf-cli.git"
  },
  "keywords": [
    "video2pdf",
    "video-to-pdf",
    "img2pdf",
    "image2pdf",
    "image-to-pdf",
    "Video To PDF CLI",
    "ffmpeg",
    "cli",
    "typescript"
  ],
  "dependencies": {
    "commander": "^14.0.3",
    "ffmpeg-static": "^5.3.0",
    "image-to-pdf": "^3.0.2",
    "ora": "^9.3.0",
    "slugify": "^1.6.9"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/compat": "^2.0.4",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.34.4",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vijayhardaha/dev-config": "^1.0.10",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "eslint": "^9.34.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "rollup": "^4.60.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
